{
  "NeurIPS": {
    "venue": "NeurIPS",
    "full_name": "Conference on Neural Information Processing Systems",
    "acceptance_rate": "25%",
    "max_pages": 10,
    "supplementary_allowed": true,
    "review_format": "double_blind",
    "required_sections": ["Limitations", "Broader Impact"],
    "preferred_types": ["method+theory", "benchmark", "empirical study", "position"],
    "mandatory_experiments": ["ablation", "computational_cost", "scalability"],
    "common_reject_reasons": [
      "incremental over concurrent work",
      "experiments only on small/toy datasets",
      "missing error bars or single seed",
      "overclaiming without sufficient evidence",
      "poor positioning relative to concurrent arXiv work"
    ],
    "reviewer_pet_peeves": [
      "claiming SOTA without recent 2024-2025 baselines",
      "no comparison with simple baselines (e.g., linear probe)",
      "figures too small to read",
      "related work missing key references"
    ],
    "writing_norms": {
      "intro_pages": "1.5-2",
      "method_detail": "high (theory + intuition)",
      "experiment_emphasis": "moderate",
      "appendix_expected": true
    },
    "anonymization_patterns": [
      "our previous work \\\\cite",
      "in our earlier paper",
      "available at https://github\\\\.com/[^}]+"
    ]
  },
